# Normalize line endings. Windows batch/PowerShell MUST be CRLF or cmd.exe can
# misbehave (e.g. a script terminating early). This forces CRLF on checkout
# regardless of the user's core.autocrlf setting.
* text=auto
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
*.py    text eol=lf
*.mjs   text eol=lf
