# ---- Build artifacts (regenerated by build_exe.bat — never commit) ----
dist/
build/
build_tmp/
*.manifest

# ---- Node deps (restored by `npm install`) ----
node_modules/

# ---- Python caches / envs ----
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# ---- Pipeline-generated OUTPUT (not source) ----
reports/
out/
**/cadpipe_reports/

# generated meshes (the only source mesh kept is samples/*.step)
*.glb
*.ply

# ---- logs / scratch ----
*_log.txt
*.log
exe_test_out.txt

# ---- OS / editor cruft ----
Thumbs.db
.DS_Store
.vscode/
.idea/
